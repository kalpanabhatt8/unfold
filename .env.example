# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Single custom auth page at /sign-in (headless UI via Clerk hooks — no prebuilt <SignIn/>).
# Both sign-in and sign-up URLs point at the same combined screen.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Database (Neon Postgres) ---
# App runtime: pooled connection string (hostname contains "-pooler").
# Example: postgresql://…@ep-xxxx-pooler.c-N.region.aws.neon.tech/neondb?sslmode=require
# Direct (non-pooler) endpoints can exhaust connections under Vercel serverless.
DATABASE_URL=
# Prisma migrate / DDL: direct (non-pooler) endpoint. Falls back to DATABASE_URL if unset.
# Set this in Vercel too so `prisma migrate deploy` during build is reliable.
DATABASE_URL_UNPOOLED=
