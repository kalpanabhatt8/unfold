# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Single custom auth page at /sign-in (headless UI via Clerk hooks — no prebuilt <SignIn/>).
# Do NOT set NEXT_PUBLIC_CLERK_SIGN_UP_URL (keeps one combined entry).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
