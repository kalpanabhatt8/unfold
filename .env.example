# Google Gemini — powers the silent sunflower companion on the journal canvas.
# Get a key at https://aistudio.google.com/apikey
# Without a key, the companion falls back to offline keyword emotion detection.
GEMINI_API_KEY=

# Dev — skip Gemini entirely (use when quota is exhausted or testing mapping only).
# COMPANION_FORCE_LOCAL=true

# Optional — override the Gemini model (defaults to gemini-2.5-flash).
# e.g. gemini-3.5-flash for newer/stronger classification.
# GEMINI_MODEL=gemini-2.5-flash
