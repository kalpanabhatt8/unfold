# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Custom auth pages at /sign-in and /sign-up (headless UI via Clerk hooks — no prebuilt <SignIn/>).
# In Clerk Dashboard → User & authentication: enable Email verification code for sign-in and sign-up; disable Password.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# --- Database (Neon Postgres) ---
# App runtime: pooled connection string (hostname contains "-pooler").
# Example: postgresql://…@ep-xxxx-pooler.c-N.region.aws.neon.tech/neondb?sslmode=require
# Direct (non-pooler) endpoints can exhaust connections under Vercel serverless.
DATABASE_URL=
# Prisma migrate / DDL: direct (non-pooler) endpoint. Falls back to DATABASE_URL if unset.
# Set this in Vercel too so `prisma migrate deploy` during build is reliable.
DATABASE_URL_UNPOOLED=

# --- Dev-only: shorten unsealed idle → implicit analysis (crisis + patterns) ---
# Honored only when NODE_ENV=development. Production always uses 24h.
# Example: 2 minutes = 120000. Restart `next dev` after changing.
# Or set in the browser console (no restart):
#   window.__UNFOLD_IMPLICIT_SEAL_INACTIVITY_MS__ = 120000
# NEXT_PUBLIC_IMPLICIT_SEAL_INACTIVITY_MS=120000
